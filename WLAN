<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SocketVerse — Learn WLAN Socket Programming</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Nunito:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --c1: #FF6B6B;
  --c2: #FFD93D;
  --c3: #6BCB77;
  --c4: #4D96FF;
  --c5: #C77DFF;
  --c6: #FF9A3C;
  --c7: #00F5D4;
  --dark: #0D0D1A;
  --dark2: #13132B;
  --dark3: #1A1A35;
  --card: #1E1E40;
  --text: #F0F0FF;
  --muted: #8888BB;
  --border: rgba(255,255,255,0.08);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  font-family:'Nunito',sans-serif;
  background:var(--dark);
  color:var(--text);
  overflow-x:hidden;
  cursor:none;
}

/* ── Custom cursor ── */
#cursor{
  position:fixed;width:18px;height:18px;
  background:var(--c2);border-radius:50%;
  pointer-events:none;z-index:9999;
  transition:transform .15s,background .2s;
  mix-blend-mode:difference;
}
#cursor-ring{
  position:fixed;width:40px;height:40px;
  border:2px solid var(--c4);border-radius:50%;
  pointer-events:none;z-index:9998;
  transition:transform .3s cubic-bezier(.17,.67,.35,1.2),opacity .2s;
  opacity:.5;
}

/* ── Animated background particles ── */
#bg-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;opacity:.35;}

/* ── Nav ── */
nav{
  position:fixed;top:0;left:0;width:100%;z-index:100;
  padding:1rem 2rem;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(13,13,26,.85);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
}
.logo{
  font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;
  background:linear-gradient(135deg,var(--c4),var(--c5),var(--c7));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
.nav-links{display:flex;gap:1.5rem;list-style:none;}
.nav-links a{
  color:var(--muted);text-decoration:none;font-weight:600;font-size:.9rem;
  transition:color .2s;letter-spacing:.03em;
}
.nav-links a:hover{color:var(--c7);}

/* ── Hero ── */
#hero{
  position:relative;z-index:1;
  min-height:100vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;text-align:center;
  padding:6rem 2rem 4rem;
  overflow:hidden;
}
.hero-badge{
  display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(77,150,255,.15);border:1px solid rgba(77,150,255,.3);
  color:var(--c4);padding:.4rem 1rem;border-radius:999px;
  font-size:.8rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  margin-bottom:1.5rem;animation:fadeUp .6s ease both;
}
.hero-title{
  font-family:'Syne',sans-serif;font-size:clamp(2.8rem,7vw,5.5rem);
  font-weight:800;line-height:1.05;
  animation:fadeUp .7s .1s ease both;
  margin-bottom:1rem;
}
.hero-title .line1{display:block;color:var(--text);}
.hero-title .line2{
  display:block;
  background:linear-gradient(90deg,var(--c1),var(--c2),var(--c3),var(--c4),var(--c5));
  background-size:200%;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  animation:gradientShift 4s linear infinite;
}
.hero-sub{
  font-size:1.15rem;color:var(--muted);max-width:600px;
  margin:0 auto 2.5rem;line-height:1.7;
  animation:fadeUp .7s .2s ease both;
}
.hero-btns{
  display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;
  animation:fadeUp .7s .3s ease both;
}
.btn{
  padding:.85rem 2rem;border-radius:12px;font-weight:700;font-size:1rem;
  cursor:none;border:none;text-decoration:none;transition:transform .2s,box-shadow .2s;
  display:inline-flex;align-items:center;gap:.5rem;
}
.btn:hover{transform:translateY(-3px);}
.btn-primary{
  background:linear-gradient(135deg,var(--c4),var(--c5));
  color:#fff;box-shadow:0 8px 30px rgba(77,150,255,.4);
}
.btn-primary:hover{box-shadow:0 12px 40px rgba(77,150,255,.6);}
.btn-secondary{
  background:transparent;color:var(--text);
  border:2px solid rgba(255,255,255,.2);
}
.btn-secondary:hover{border-color:var(--c7);color:var(--c7);}

/* Floating nodes animation */
.float-nodes{position:absolute;width:100%;height:100%;top:0;left:0;pointer-events:none;}
.fnode{
  position:absolute;border-radius:50%;
  animation:floatNode 6s ease-in-out infinite;
  opacity:.6;
}

/* ── Section common ── */
section{position:relative;z-index:1;padding:5rem 2rem;}
.section-label{
  font-family:'Space Mono',monospace;
  font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;
  color:var(--c7);margin-bottom:.75rem;
}
.section-title{
  font-family:'Syne',sans-serif;font-size:clamp(1.8rem,4vw,2.8rem);
  font-weight:800;margin-bottom:1rem;
}
.section-sub{color:var(--muted);font-size:1.05rem;line-height:1.7;max-width:600px;}
.container{max-width:1200px;margin:0 auto;}

/* ── Concept cards (ch2) ── */
#concepts{background:var(--dark2);}
.concepts-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:1.5rem;margin-top:3rem;
}
.concept-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:20px;padding:2rem;
  transition:transform .3s,box-shadow .3s;
  position:relative;overflow:hidden;cursor:none;
}
.concept-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--accent);
}
.concept-card:hover{transform:translateY(-6px);box-shadow:0 20px 60px rgba(0,0,0,.4);}
.concept-icon{
  font-size:2.5rem;margin-bottom:1rem;
  display:inline-block;animation:bounce 2s ease-in-out infinite;
}
.concept-card h3{font-family:'Syne',sans-serif;font-size:1.1rem;margin-bottom:.5rem;}
.concept-card p{color:var(--muted);font-size:.9rem;line-height:1.6;}
.tag{
  display:inline-block;margin-top:1rem;
  padding:.25rem .75rem;border-radius:999px;font-size:.75rem;font-weight:700;
  background:rgba(255,255,255,.07);color:var(--accent);
}

/* ── Socket lifecycle interactive ── */
#lifecycle{background:var(--dark3);}
.lifecycle-wrapper{
  display:flex;gap:2rem;margin-top:3rem;flex-wrap:wrap;
}
.lifecycle-steps{
  flex:1;min-width:280px;
  display:flex;flex-direction:column;gap:.75rem;
}
.step-btn{
  background:var(--card);border:2px solid transparent;
  border-radius:14px;padding:1rem 1.5rem;
  cursor:none;text-align:left;color:var(--text);
  transition:all .25s;display:flex;align-items:center;gap:1rem;
  font-family:'Nunito',sans-serif;font-size:.95rem;font-weight:700;
}
.step-btn:hover,.step-btn.active{
  border-color:var(--step-color);
  background:rgba(255,255,255,.05);
  transform:translateX(6px);
}
.step-btn.active{background:rgba(255,255,255,.08);}
.step-num{
  width:36px;height:36px;border-radius:50%;
  background:var(--step-color);color:#000;
  display:flex;align-items:center;justify-content:center;
  font-weight:900;font-size:.85rem;flex-shrink:0;
}
.lifecycle-display{
  flex:1.5;min-width:300px;
  background:var(--card);border-radius:20px;border:1px solid var(--border);
  padding:2rem;transition:all .3s;
}
.life-title{
  font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;margin-bottom:.5rem;
}
.life-desc{color:var(--muted);line-height:1.7;margin-bottom:1.5rem;font-size:.95rem;}
.life-code{
  background:#0A0A1A;border-radius:12px;padding:1.25rem;
  font-family:'Space Mono',monospace;font-size:.82rem;
  color:#A9B1D6;line-height:1.8;border:1px solid rgba(255,255,255,.06);
  white-space:pre;overflow-x:auto;
}
.life-code .kw{color:#7AA2F7;}
.life-code .fn{color:#7DCFFF;}
.life-code .str{color:#9ECE6A;}
.life-code .cm{color:#565F89;font-style:italic;}
.life-code .num{color:#FF9E64;}
.progress-bar{
  height:4px;background:rgba(255,255,255,.1);border-radius:2px;
  margin-top:1.5rem;overflow:hidden;
}
.progress-fill{
  height:100%;border-radius:2px;transition:width .4s ease;
  background:linear-gradient(90deg,var(--c4),var(--c5));
}

/* ── Quiz ── */
#quiz{background:var(--dark2);}
.quiz-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:24px;padding:2.5rem;max-width:750px;margin:3rem auto 0;
}
.quiz-header{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:2rem;
}
.quiz-counter{
  font-family:'Space Mono',monospace;font-size:.85rem;color:var(--muted);
}
.quiz-score-badge{
  background:rgba(107,203,119,.15);color:var(--c3);
  padding:.3rem .9rem;border-radius:999px;font-weight:700;font-size:.85rem;
}
.quiz-question{
  font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:700;
  margin-bottom:1.5rem;line-height:1.4;
}
.quiz-options{display:flex;flex-direction:column;gap:.75rem;}
.quiz-opt{
  background:rgba(255,255,255,.04);border:2px solid rgba(255,255,255,.1);
  border-radius:12px;padding:1rem 1.25rem;
  cursor:none;text-align:left;color:var(--text);
  font-family:'Nunito',sans-serif;font-size:.95rem;font-weight:600;
  transition:all .2s;display:flex;align-items:center;gap:1rem;
}
.quiz-opt:hover{border-color:var(--c4);background:rgba(77,150,255,.08);}
.quiz-opt.correct{border-color:var(--c3)!important;background:rgba(107,203,119,.15)!important;}
.quiz-opt.wrong{border-color:var(--c1)!important;background:rgba(255,107,107,.12)!important;}
.opt-letter{
  width:28px;height:28px;border-radius:8px;
  background:rgba(255,255,255,.08);
  display:flex;align-items:center;justify-content:center;
  font-family:'Space Mono',monospace;font-size:.75rem;font-weight:700;
  flex-shrink:0;transition:background .2s;
}
.quiz-opt.correct .opt-letter{background:var(--c3);color:#000;}
.quiz-opt.wrong .opt-letter{background:var(--c1);color:#fff;}
.quiz-feedback{
  margin-top:1.25rem;padding:1rem 1.25rem;
  border-radius:12px;font-size:.9rem;line-height:1.6;
  display:none;
}
.quiz-feedback.show{display:block;}
.quiz-feedback.correct{background:rgba(107,203,119,.1);color:var(--c3);border:1px solid rgba(107,203,119,.3);}
.quiz-feedback.wrong{background:rgba(255,107,107,.1);color:var(--c1);border:1px solid rgba(255,107,107,.3);}
.quiz-next{
  margin-top:1.5rem;width:100%;
  background:linear-gradient(135deg,var(--c4),var(--c5));
  color:#fff;padding:1rem;border-radius:12px;
  border:none;font-weight:700;font-size:1rem;
  cursor:none;display:none;transition:opacity .2s,transform .2s;
}
.quiz-next.show{display:block;}
.quiz-next:hover{transform:translateY(-2px);}

/* ── Code playground ── */
#playground{background:var(--dark3);}
.playground-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:3rem;
}
@media(max-width:700px){.playground-grid{grid-template-columns:1fr;}}
.editor-pane{
  background:#0A0A1A;border-radius:20px;border:1px solid var(--border);
  overflow:hidden;
}
.editor-header{
  padding:.75rem 1.25rem;background:rgba(255,255,255,.04);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.editor-dots{display:flex;gap:.4rem;}
.dot{width:12px;height:12px;border-radius:50%;}
.dot:nth-child(1){background:#FF5F57;}
.dot:nth-child(2){background:#FFBD2E;}
.dot:nth-child(3){background:#28C840;}
.editor-label{
  font-family:'Space Mono',monospace;font-size:.75rem;color:var(--muted);
}
.code-display{
  padding:1.5rem;font-family:'Space Mono',monospace;font-size:.78rem;
  color:#A9B1D6;line-height:1.9;white-space:pre;overflow-x:auto;
  height:340px;overflow-y:auto;
}
.code-display::-webkit-scrollbar{width:4px;}
.code-display::-webkit-scrollbar-track{background:transparent;}
.code-display::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:2px;}
.run-btn{
  margin:0 1.5rem 1.5rem;width:calc(100% - 3rem);
  background:linear-gradient(135deg,var(--c3),var(--c7));
  color:#000;border:none;padding:.85rem;border-radius:12px;
  font-weight:900;font-size:.9rem;cursor:none;
  transition:transform .2s,box-shadow .2s;
  font-family:'Nunito',sans-serif;
}
.run-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(107,203,119,.3);}
.output-pane{
  background:#050510;border-radius:20px;border:1px solid var(--border);
  overflow:hidden;
}
.output-body{
  padding:1.5rem;font-family:'Space Mono',monospace;font-size:.8rem;
  line-height:1.8;height:calc(100% - 44px);overflow-y:auto;
}
.out-line{opacity:0;animation:typeIn .3s ease forwards;}
.out-prompt{color:var(--c3);}
.out-info{color:var(--c4);}
.out-success{color:var(--c7);}
.out-warn{color:var(--c2);}
.out-data{color:var(--c5);}

/* ── Diagram ── */
#diagram{background:var(--dark2);}
.dia-container{
  margin-top:3rem;
  background:var(--card);border:1px solid var(--border);
  border-radius:24px;padding:2rem;overflow-x:auto;
}
.dia-row{
  display:flex;align-items:center;justify-content:center;
  gap:1rem;margin:.5rem 0;flex-wrap:nowrap;
  min-width:600px;
}
.dia-box{
  padding:.6rem 1.2rem;border-radius:10px;
  font-family:'Space Mono',monospace;font-size:.78rem;font-weight:700;
  text-align:center;min-width:120px;position:relative;cursor:none;
  transition:transform .2s,box-shadow .2s;
}
.dia-box:hover{transform:scale(1.05);}
.dia-box.server{background:rgba(77,150,255,.2);border:1.5px solid var(--c4);color:var(--c4);}
.dia-box.client{background:rgba(199,125,255,.2);border:1.5px solid var(--c5);color:var(--c5);}
.dia-box.network{background:rgba(0,245,212,.15);border:1.5px solid var(--c7);color:var(--c7);}
.dia-arrow{color:var(--muted);font-size:1.2rem;flex-shrink:0;}
.dia-label{
  font-size:.7rem;color:var(--muted);text-align:center;margin:.15rem 0;
  font-family:'Space Mono',monospace;
}
.dia-section-label{
  font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  padding:.3rem .8rem;border-radius:6px;
}
.dia-section-label.s{background:rgba(77,150,255,.15);color:var(--c4);}
.dia-section-label.c{background:rgba(199,125,255,.15);color:var(--c5);}
.tooltip-hint{
  position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);
  background:var(--dark);border:1px solid var(--border);
  padding:.5rem .75rem;border-radius:8px;font-size:.72rem;
  white-space:nowrap;color:var(--text);
  opacity:0;pointer-events:none;transition:opacity .2s;z-index:10;
}
.dia-box:hover .tooltip-hint{opacity:1;}

/* ── Progress tracker ── */
#tracker{background:var(--dark3);}
.track-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;margin-top:3rem;}
.track-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:16px;padding:1.5rem;cursor:none;
  transition:transform .2s;position:relative;overflow:hidden;
}
.track-card:hover{transform:translateY(-4px);}
.track-card.done{border-color:rgba(107,203,119,.3);}
.track-check{
  width:32px;height:32px;border-radius:50%;
  border:2px solid rgba(255,255,255,.2);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:1rem;font-size:.9rem;
  transition:all .3s;cursor:none;
}
.track-card.done .track-check{
  background:var(--c3);border-color:var(--c3);color:#000;font-weight:900;
}
.track-card h4{font-size:.9rem;font-weight:700;margin-bottom:.4rem;}
.track-card p{font-size:.8rem;color:var(--muted);line-height:1.5;}
.xp-bar{height:3px;background:rgba(255,255,255,.08);border-radius:2px;margin-top:1rem;}
.xp-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--c3),var(--c7));width:0;transition:width 1s ease;}

/* ── Cheat sheet ── */
#cheatsheet{background:var(--dark2);}
.cs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;margin-top:3rem;}
.cs-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:16px;overflow:hidden;
}
.cs-header{
  padding:.75rem 1.25rem;display:flex;align-items:center;justify-content:space-between;
}
.cs-fn{font-family:'Space Mono',monospace;font-size:.9rem;font-weight:700;}
.cs-badge{
  font-size:.65rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  padding:.2rem .6rem;border-radius:999px;
}
.cs-body{
  padding:1rem 1.25rem;
  font-family:'Space Mono',monospace;font-size:.75rem;
  color:#8899BB;line-height:1.7;border-top:1px solid var(--border);
}
.cs-desc{padding:.75rem 1.25rem;font-size:.82rem;color:var(--muted);line-height:1.5;}

/* ── Footer ── */
footer{
  position:relative;z-index:1;
  background:var(--dark);border-top:1px solid var(--border);
  padding:3rem 2rem;text-align:center;
}
.footer-logo{
  font-family:'Syne',sans-serif;font-size:1.8rem;font-weight:800;
  background:linear-gradient(135deg,var(--c4),var(--c5));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-bottom:.5rem;
}
footer p{color:var(--muted);font-size:.9rem;}

/* ── Animations ── */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(24px);}
  to{opacity:1;transform:translateY(0);}
}
@keyframes gradientShift{
  0%{background-position:0% 50%;}100%{background-position:200% 50%;}
}
@keyframes bounce{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(-6px);}
}
@keyframes floatNode{
  0%,100%{transform:translateY(0) scale(1);}
  50%{transform:translateY(-20px) scale(1.05);}
}
@keyframes typeIn{
  from{opacity:0;transform:translateX(-8px);}
  to{opacity:1;transform:translateX(0);}
}
@keyframes pulse{
  0%,100%{box-shadow:0 0 0 0 rgba(77,150,255,.4);}
  50%{box-shadow:0 0 0 12px rgba(77,150,255,0);}
}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}

.reveal{opacity:0;transform:translateY(30px);transition:opacity .6s ease,transform .6s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}
</style>
</head>
<body>

<div id="cursor"></div>
<div id="cursor-ring"></div>
<canvas id="bg-canvas"></canvas>

<!-- NAV -->
<nav>
  <div class="logo">⚡ SocketVerse</div>
  <ul class="nav-links">
    <li><a href="#concepts">Concepts</a></li>
    <li><a href="#lifecycle">Lifecycle</a></li>
    <li><a href="#playground">Code Lab</a></li>
    <li><a href="#quiz">Quiz</a></li>
    <li><a href="#cheatsheet">Cheat Sheet</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="float-nodes">
    <div class="fnode" style="width:80px;height:80px;background:rgba(77,150,255,.12);top:15%;left:8%;animation-delay:0s;animation-duration:7s;"></div>
    <div class="fnode" style="width:50px;height:50px;background:rgba(199,125,255,.15);top:60%;left:5%;animation-delay:1s;animation-duration:5s;"></div>
    <div class="fnode" style="width:100px;height:100px;background:rgba(0,245,212,.08);top:20%;right:10%;animation-delay:2s;animation-duration:8s;"></div>
    <div class="fnode" style="width:60px;height:60px;background:rgba(255,107,107,.12);bottom:20%;right:8%;animation-delay:.5s;animation-duration:6s;"></div>
    <div class="fnode" style="width:40px;height:40px;background:rgba(255,217,61,.15);bottom:30%;left:15%;animation-delay:1.5s;animation-duration:5.5s;"></div>
  </div>
  <div class="hero-badge">🌐 Interactive Learning Platform</div>
  <h1 class="hero-title">
    <span class="line1">Master WLAN</span>
    <span class="line2">Socket Programming</span>
