<script>
// ── Cursor ──────────────────────────────────────────────────────
const cur = document.getElementById('cursor');
const ring = document.getElementById('cursor-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cur.style.left=(mx-9)+'px';cur.style.top=(my-9)+'px';
});
function animRing(){
  rx+=(mx-rx-20)*.12;ry+=(my-ry-20)*.12;
  ring.style.left=rx+'px';ring.style.top=ry+'px';
  requestAnimationFrame(animRing);
}animAnimRing=animRing;animRing();

// ── BG Canvas particles ─────────────────────────────────────────
const canvas=document.getElementById('bg-canvas');
const ctx=canvas.getContext('2d');
let particles=[];
function resizeCanvas(){canvas.width=window.innerWidth;canvas.height=window.innerHeight;}
resizeCanvas();window.addEventListener('resize',resizeCanvas);

const colors=['#4D96FF','#C77DFF','#00F5D4','#FF6B6B','#FFD93D','#6BCB77'];
for(let i=0;i<60;i++){
  particles.push({
    x:Math.random()*window.innerWidth,
    y:Math.random()*window.innerHeight,
    r:Math.random()*2+1,
    dx:(Math.random()-.5)*.4,
    dy:(Math.random()-.5)*.4,
    c:colors[Math.floor(Math.random()*colors.length)],
    a:Math.random()*.6+.2
  });
}
function drawParticles(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  particles.forEach(p=>{
    ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
    ctx.fillStyle=p.c;ctx.globalAlpha=p.a;ctx.fill();
    p.x+=p.dx;p.y+=p.dy;
    if(p.x<0||p.x>canvas.width)p.dx*=-1;
    if(p.y<0||p.y>canvas.height)p.dy*=-1;
  });
  // draw connections
  ctx.globalAlpha=1;
  for(let i=0;i<particles.length;i++){
    for(let j=i+1;j<particles.length;j++){
      const d=Math.hypot(particles[i].x-particles[j].x,particles[i].y-particles[j].y);
      if(d<120){
        ctx.beginPath();
        ctx.moveTo(particles[i].x,particles[i].y);
        ctx.lineTo(particles[j].x,particles[j].y);
        ctx.strokeStyle=particles[i].c;
        ctx.globalAlpha=(1-d/120)*.15;
        ctx.lineWidth=.5;ctx.stroke();
      }
    }
  }
  ctx.globalAlpha=1;
  requestAnimationFrame(drawParticles);
}drawParticles();

// ── Scroll reveal ───────────────────────────────────────────────
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});
},{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// ── Lifecycle steps ─────────────────────────────────────────────
const steps=[
  {label:'socket()',color:'#4D96FF',side:'Both',
   title:'Step 1 — Create the Socket',
   desc:'The very first call. socket() asks the OS to create a new communication endpoint and returns a file descriptor (an integer) that represents it. Think of it like plugging in a phone before you can dial.',
   code:`<span class="kw">int</span> server_fd;

<span class="cm">/* AF_INET = IPv4, SOCK_STREAM = TCP */</span>
server_fd = <span class="fn">socket</span>(<span class="num">AF_INET</span>, <span class="num">SOCK_STREAM</span>, <span class="num">0</span>);

<span class="kw">if</span> (server_fd == <span class="num">-1</span>) {
    <span class="fn">perror</span>(<span class="str">"socket() failed"</span>);
    <span class="fn">exit</span>(<span class="num">EXIT_FAILURE</span>);
}
<span class="cm">/* server_fd is now a valid file descriptor */</span>`},
  {label:'bind()',color:'#FFD93D',side:'Server',
   title:'Step 2 — Bind to an Address',
   desc:'bind() ties the socket to a specific IP address and port number on this machine. Using INADDR_ANY (0.0.0.0) means "listen on ALL interfaces" — including the Wi-Fi adapter — so WLAN clients can reach us.',
   code:`<span class="kw">struct</span> sockaddr_in address;
address.sin_family      = AF_INET;
address.sin_addr.s_addr = <span class="num">INADDR_ANY</span>; <span class="cm">/* all interfaces */</span>
address.sin_port        = <span class="fn">htons</span>(<span class="num">8080</span>);  <span class="cm">/* network byte order */</span>

<span class="kw">if</span> (<span class="fn">bind</span>(server_fd,
         (<span class="kw">struct</span> sockaddr *)&address,
         <span class="kw">sizeof</span>(address)) < <span class="num">0</span>) {
    <span class="fn">perror</span>(<span class="str">"bind() failed"</span>);
    <span class="fn">exit</span>(<span class="num">EXIT_FAILURE</span>);
}`},
  {label:'listen()',color:'#6BCB77',side:'Server',
   title:'Step 3 — Start Listening',
   desc:'listen() marks the socket as passive — it will now accept incoming connections. The backlog parameter (3) sets how many pending connections can queue up before the OS starts refusing new ones.',
   code:`<span class="cm">/* Backlog = 3: up to 3 pending connections */</span>
<span class="kw">if</span> (<span class="fn">listen</span>(server_fd, <span class="num">3</span>) < <span class="num">0</span>) {
    <span class="fn">perror</span>(<span class="str">"listen() failed"</span>);
    <span class="fn">exit</span>(<span class="num">EXIT_FAILURE</span>);
}

<span class="fn">printf</span>(<span class="str">"Server listening on port 8080...\\n"</span>);`},
  {label:'connect()',color:'#C77DFF',side:'Client',
   title:'Step 4 — Client Connects (TCP Handshake)',
   desc:'On the CLIENT side, connect() initiates the TCP 3-way handshake to the server\'s WLAN IP. This call blocks until the connection is established or fails. The server\'s IP must be its LAN address (e.g. 192.168.1.10).',
   code:`<span class="kw">struct</span> sockaddr_in server_addr;
server_addr.sin_family = AF_INET;
server_addr.sin_port   = <span class="fn">htons</span>(<span class="num">8080</span>);

<span class="cm">/* Use WLAN IP, NOT 127.0.0.1! */</span>
<span class="fn">inet_pton</span>(AF_INET, <span class="str">"192.168.1.10"</span>,
          &server_addr.sin_addr);

<span class="kw">if</span> (<span class="fn">connect</span>(sock_fd,
             (<span class="kw">struct</span> sockaddr *)&server_addr,
             <span class="kw">sizeof</span>(server_addr)) < <span class="num">0</span>) {
    <span class="fn">perror</span>(<span class="str">"connect() failed"</span>);
}`},
  {label:'accept()',color:'#FF6B6B',side:'Server',
   title:'Step 5 — Server Accepts Connection',
   desc:'accept() blocks on the server side until a client connects. When it returns, you get a NEW socket fd (client_fd) dedicated to that single client. The original server_fd keeps listening for more clients.',
   code:`<span class="kw">int</span> client_fd;
<span class="kw">int</span> addrlen = <span class="kw">sizeof</span>(address);

<span class="cm">/* Blocks until a client connects */</span>
client_fd = <span class="fn">accept</span>(server_fd,
                    (<span class="kw">struct</span> sockaddr *)&address,
                    (<span class="kw">socklen_t</span> *)&addrlen);

<span class="kw">char</span> ip[INET_ADDRSTRLEN];
<span class="fn">inet_ntop</span>(AF_INET, &address.sin_addr,
          ip, INET_ADDRSTRLEN);
<span class="fn">printf</span>(<span class="str">"Client from: %s\\n"</span>, ip);`},
  {label:'send()/recv()',color:'#00F5D4',side:'Both',
   title:'Step 6 — Exchange Data',
   desc:'Now data flows! send() puts bytes into the TCP send buffer; the OS handles the actual delivery. recv() reads from the receive buffer. Always loop on both — they may not send/receive everything in one call.',
   code:`<span class="kw">char</span> buffer[<span class="num">1024</span>];

<span class="cm">/* Server: echo loop */</span>
<span class="kw">while</span> (<span class="num">1</span>) {
    <span class="fn">memset</span>(buffer, <span class="num">0</span>, <span class="kw">sizeof</span>(buffer));
    <span class="kw">int</span> n = <span class="fn">recv</span>(client_fd, buffer,
                    <span class="kw">sizeof</span>(buffer), <span class="num">0</span>);
    <span class="kw">if</span> (n <= <span class="num">0</span>) <span class="kw">break</span>; <span class="cm">/* disconnected */</span>

    <span class="fn">printf</span>(<span class="str">"Got: %s"</span>, buffer);
    <span class="fn">send</span>(client_fd, buffer, n, <span class="num">0</span>); <span class="cm">/* echo */</span>
}`},
  {label:'close()',color:'#FF9A3C',side:'Both',
   title:'Step 7 — Close the Connection',
   desc:'close() sends a FIN packet, initiating graceful TCP teardown. Always close BOTH the client_fd and the server_fd when done. Forgetting to close sockets causes resource leaks in long-running servers.',
   code:`<span class="cm">/* Server: close both fds */</span>
<span class="fn">close</span>(client_fd);  <span class="cm">/* close this client */</span>
<span class="fn">close</span>(server_fd);  <span class="cm">/* stop listening */</span>

<span class="cm">/* Client: close its socket */</span>
<span class="fn">close</span>(sock_fd);

<span class="cm">/* TCP sends FIN → FIN-ACK → ACK */</span>
<span class="cm">/* Connection is fully torn down */</span>`},
];

function renderSteps(){
  const c=document.getElementById('steps-container');
  steps.forEach((s,i)=>{
    const btn=document.createElement('button');
    btn.className='step-btn';
    btn.style.setProperty('--step-color',s.color);
    btn.innerHTML=`<div class="step-num" style="background:${s.color}">${i+1}</div>
      <div>
        <div style="font-family:'Space Mono',monospace;font-size:.85rem">${s.label}</div>
        <div style="font-size:.75rem;color:var(--muted);font-weight:400">${s.side}</div>
      </div>`;
    btn.onclick=()=>showStep(i);
    c.appendChild(btn);
  });
}

function showStep(i){
  document.querySelectorAll('.step-btn').forEach((b,j)=>{
    b.classList.toggle('active',j===i);
  });
  const s=steps[i];
  document.getElementById('life-title').textContent=s.title;
  document.getElementById('life-desc').textContent=s.desc;
  document.getElementById('life-code').innerHTML=s.code;
  document.getElementById('progress-fill').style.width=((i+1)/steps.length*100)+'%';
}

renderSteps();

// ── Code playground ─────────────────────────────────────────────
const codes={
  server:{
    file:'server.c',
    code:`<span class="kw">#include</span> <span class="str">&lt;stdio.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;stdlib.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;string.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;unistd.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;arpa/inet.h&gt;</span>

<span class="kw">#define</span> PORT        <span class="num">8080</span>
<span class="kw">#define</span> BUFFER_SIZE <span class="num">1024</span>

<span class="kw">int</span> <span class="fn">main</span>() {
    <span class="kw">int</span> server_fd, client_fd;
    <span class="kw">struct</span> sockaddr_in address;
    <span class="kw">char</span> buffer[BUFFER_SIZE];
    <span class="kw">int</span> addrlen = <span class="kw">sizeof</span>(address);

    <span class="cm">/* 1. Create socket */</span>
    server_fd = <span class="fn">socket</span>(AF_INET, SOCK_STREAM, <span class="num">0</span>);

    <span class="cm">/* 2. Allow port reuse */</span>
    <span class="kw">int</span> opt = <span class="num">1</span>;
    <span class="fn">setsockopt</span>(server_fd, SOL_SOCKET,
               SO_REUSEADDR, &opt, <span class="kw">sizeof</span>(opt));

    <span class="cm">/* 3. Bind to all interfaces (WLAN incl.) */</span>
    address.sin_family      = AF_INET;
    address.sin_addr.s_addr = INADDR_ANY;
    address.sin_port        = <span class="fn">htons</span>(PORT);
    <span class="fn">bind</span>(server_fd, (<span class="kw">struct</span> sockaddr *)&address,
         <span class="kw">sizeof</span>(address));

    <span class="cm">/* 4. Listen */</span>
    <span class="fn">listen</span>(server_fd, <span class="num">3</span>);
    <span class="fn">printf</span>(<span class="str">"Server listening on port %d...\\n"</span>, PORT);

    <span class="cm">/* 5. Accept a client */</span>
    client_fd = <span class="fn">accept</span>(server_fd,
                  (<span class="kw">struct</span> sockaddr *)&address,
                  (<span class="kw">socklen_t</span> *)&addrlen);

    <span class="cm">/* 6. Echo loop */</span>
    <span class="kw">while</span> (<span class="num">1</span>) {
        <span class="fn">memset</span>(buffer, <span class="num">0</span>, BUFFER_SIZE);
        <span class="kw">int</span> n = <span class="fn">read</span>(client_fd, buffer, BUFFER_SIZE);
        <span class="kw">if</span> (n <= <span class="num">0</span>) <span class="kw">break</span>;
        <span class="fn">printf</span>(<span class="str">"Client: %s"</span>, buffer);
        <span class="fn">send</span>(client_fd, buffer, n, <span class="num">0</span>);
    }
    <span class="fn">close</span>(client_fd); <span class="fn">close</span>(server_fd);
    <span class="kw">return</span> <span class="num">0</span>;
}`,
