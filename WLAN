  multiclient:{
    file:'server_multiclient.c',
    code:`<span class="kw">#include</span> <span class="str">&lt;sys/select.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;stdio.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;arpa/inet.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;unistd.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;string.h&gt;</span>

<span class="kw">#define</span> PORT <span class="num">8080</span>
<span class="kw">#define</span> BUF  <span class="num">1024</span>

<span class="kw">int</span> <span class="fn">main</span>() {
    fd_set readfds;
    <span class="kw">int</span> clients[FD_SETSIZE], max_fd;
    <span class="kw">char</span> buf[BUF];

    <span class="kw">for</span>(<span class="kw">int</span> i=<span class="num">0</span>; i<FD_SETSIZE; i++) clients[i]=-<span class="num">1</span>;

    <span class="kw">int</span> srv = <span class="fn">socket</span>(AF_INET, SOCK_STREAM, <span class="num">0</span>);
    <span class="kw">struct</span> sockaddr_in addr = {
        .sin_family=AF_INET,
        .sin_addr.s_addr=INADDR_ANY,
        .sin_port=<span class="fn">htons</span>(PORT)
    };
    <span class="fn">bind</span>(srv,(<span class="kw">struct</span> sockaddr*)&addr,<span class="kw">sizeof</span>(addr));
    <span class="fn">listen</span>(srv, <span class="num">10</span>);
    max_fd = srv;

    <span class="kw">while</span>(<span class="num">1</span>) {
        FD_ZERO(&readfds);
        FD_SET(srv, &readfds);
        <span class="kw">for</span>(<span class="kw">int</span> i=<span class="num">0</span>;i<FD_SETSIZE;i++)
            <span class="kw">if</span>(clients[i]><span class="num">0</span>) FD_SET(clients[i],&readfds);

        <span class="fn">select</span>(max_fd+<span class="num">1</span>, &readfds, NULL, NULL, NULL);

        <span class="cm">/* New connection? */</span>
        <span class="kw">if</span>(FD_ISSET(srv, &readfds)) {
            <span class="kw">int</span> nfd = <span class="fn">accept</span>(srv,NULL,NULL);
            <span class="kw">for</span>(<span class="kw">int</span> i=<span class="num">0</span>;i<FD_SETSIZE;i++)
                <span class="kw">if</span>(clients[i]<<span class="num">0</span>) { clients[i]=nfd; <span class="kw">break</span>; }
            <span class="kw">if</span>(nfd>max_fd) max_fd=nfd;
        }
        <span class="cm">/* Existing client data? */</span>
        <span class="kw">for</span>(<span class="kw">int</span> i=<span class="num">0</span>;i<FD_SETSIZE;i++) {
            <span class="kw">if</span>(clients[i]><span class="num">0</span> &&
               FD_ISSET(clients[i],&readfds)) {
                <span class="kw">int</span> n=<span class="fn">read</span>(clients[i],buf,BUF);
                <span class="kw">if</span>(n<=<span class="num">0</span>) {
                    <span class="fn">close</span>(clients[i]);
                    clients[i]=-<span class="num">1</span>;
                } <span class="kw">else</span> {
                    <span class="fn">send</span>(clients[i],buf,n,<span class="num">0</span>);
                }
            }
        }
    }
}`,
