    code:`<span class="kw">#include</span> <span class="str">&lt;stdio.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;stdlib.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;string.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;unistd.h&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;arpa/inet.h&gt;</span>

<span class="kw">#define</span> PORT      <span class="num">8080</span>
<span class="kw">#define</span> BUF_SIZE  <span class="num">1024</span>
<span class="kw">#define</span> SERVER_IP <span class="str">"192.168.1.10"</span>  <span class="cm">/* WLAN IP */</span>

<span class="kw">int</span> <span class="fn">main</span>() {
    <span class="kw">int</span> sock_fd;
    <span class="kw">struct</span> sockaddr_in server_addr;
    <span class="kw">char</span> buf[BUF_SIZE], msg[BUF_SIZE];

    <span class="cm">/* 1. Create socket */</span>
    sock_fd = <span class="fn">socket</span>(AF_INET, SOCK_STREAM, <span class="num">0</span>);

    <span class="cm">/* 2. Set up server address */</span>
    server_addr.sin_family = AF_INET;
    server_addr.sin_port   = <span class="fn">htons</span>(PORT);
    <span class="fn">inet_pton</span>(AF_INET, SERVER_IP,
