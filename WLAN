// ── Quiz ────────────────────────────────────────────────────────
const questions=[
  {q:"What system call creates a socket file descriptor?",opts:["bind()","socket()","listen()","connect()"],ans:1,exp:"socket() creates the communication endpoint and returns a file descriptor. It's always the first call in both server and client code."},
  {q:"Which constant should a server use for sin_addr to accept WLAN connections?",opts:["LOCALHOST","127.0.0.1","INADDR_ANY","AF_INET"],ans:2,exp:"INADDR_ANY (0.0.0.0) binds to ALL network interfaces, including the Wi-Fi adapter, making the server reachable from other devices on the same WLAN."},
  {q:"What does htons() do?",opts:["Converts a host string to network string","Converts a host short to network byte order","Creates a host socket","Hashes network traffic"],ans:1,exp:"htons() = 'host to network short'. It converts a 16-bit integer (port number) from the host's byte order to big-endian (network byte order). Essential before putting a port in sockaddr_in."},
  {q:"Which system call on the CLIENT initiates the TCP 3-way handshake?",opts:["bind()","accept()","connect()","listen()"],ans:2,exp:"connect() sends the initial SYN packet to the server, triggering the TCP 3-way handshake (SYN → SYN-ACK → ACK). It blocks until the connection is fully established."},
  {q:"What does accept() return?",opts:["The port number","A new socket fd for the connected client","The client's IP address","The number of pending connections"],ans:1,exp:"accept() returns a NEW file descriptor dedicated to communicating with that specific client. The original server_fd continues listening for more connections."},
  {q:"If recv() returns 0, what does it mean?",opts:["No data available yet","The client cleanly disconnected","An error occurred","The buffer is full"],ans:1,exp:"recv() returning 0 means the remote peer closed the connection gracefully (sent a FIN). You should break out of the loop and close the socket on your side."},
  {q:"What is the purpose of SO_REUSEADDR socket option?",opts:["Allows the socket to send to multiple addresses","Allows the port to be reused immediately after server exit","Increases buffer size","Enables broadcast mode"],ans:1,exp:"SO_REUSEADDR lets you restart your server immediately after it exits without waiting for the OS TIME_WAIT state to expire. Without it you get 'Address already in use' errors."},
  {q:"Which function converts a dotted IP string (e.g. '192.168.1.10') to binary?",opts:["atoi()","inet_addr()","inet_pton()","gethostbyname()"],ans:2,exp:"inet_pton() = 'presentation to network'. It converts an IP address string to its binary network representation, storing it in sin_addr. It supports both IPv4 (AF_INET) and IPv6 (AF_INET6)."},
  {q:"What does select() allow a server to do?",opts:["Select the fastest network interface","Monitor multiple file descriptors for readability","Choose between TCP and UDP","Select a specific WLAN channel"],ans:1,exp:"select() lets a single-threaded server monitor multiple socket file descriptors simultaneously. When data arrives on any of them, select() returns and you can handle it — no threads needed!"},
  {q:"A client wants to connect to a server on the SAME Wi-Fi network. What IP should it use?",opts:["127.0.0.1 (localhost)","255.255.255.255 (broadcast)","The server's WLAN IP (e.g. 192.168.1.10)","0.0.0.0"],ans:2,exp:"localhost (127.0.0.1) only works within the same machine. To communicate across Wi-Fi, the client must use the server's actual LAN IP address assigned by the router (e.g. 192.168.1.10). Find it with 'ip a' on Linux."},
];

let qIndex=0,score=0,answered=false;

function renderQuestion(){
  const q=questions[qIndex];
  document.getElementById('q-counter').textContent=`Question ${qIndex+1} of ${questions.length}`;
  document.getElementById('q-score').textContent=`Score: ${score}`;
  document.getElementById('q-text').textContent=q.q;
  document.getElementById('q-feedback').className='quiz-feedback';
  document.getElementById('q-feedback').textContent='';
  document.getElementById('q-next').className='quiz-next';
  answered=false;
  const opts=document.getElementById('q-options');
  opts.innerHTML='';
  ['A','B','C','D'].forEach((letter,i)=>{
    const btn=document.createElement('button');
    btn.className='quiz-opt';
    btn.innerHTML=`<span class="opt-letter">${letter}</span>${q.opts[i]}`;
    btn.onclick=()=>answer(i,btn);
    opts.appendChild(btn);
  });
}

function answer(i,btn){
  if(answered)return;
  answered=true;
  const q=questions[qIndex];
  const fb=document.getElementById('q-feedback');
  const opts=document.querySelectorAll('.quiz-opt');
  opts[q.ans].classList.add('correct');
  if(i===q.ans){
    score++;
    fb.textContent='✅ Correct! '+q.exp;
    fb.className='quiz-feedback correct show';
  }else{
    btn.classList.add('wrong');
    fb.textContent='❌ Not quite. '+q.exp;
    fb.className='quiz-feedback wrong show';
  }
  document.getElementById('q-score').textContent=`Score: ${score}`;
  document.getElementById('q-next').className='quiz-next show';
}

function nextQuestion(){
  qIndex++;
  if(qIndex>=questions.length){
    const pct=Math.round(score/questions.length*100);
    const emoji=pct===100?'🏆':pct>=80?'🎉':pct>=60?'👍':'📚';
    document.getElementById('q-text').textContent=`${emoji} Quiz Complete! You scored ${score}/${questions.length} (${pct}%)`;
    document.getElementById('q-options').innerHTML='';
    document.getElementById('q-feedback').className='quiz-feedback';
    document.getElementById('q-next').innerHTML='🔄 Restart Quiz';
    document.getElementById('q-next').className='quiz-next show';
    document.getElementById('q-next').onclick=()=>{qIndex=0;score=0;renderQuestion();document.getElementById('q-next').onclick=nextQuestion;};
    return;
  }
  renderQuestion();
}
renderQuestion();

