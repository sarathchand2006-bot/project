        <span class="fn">memset</span>(buf, <span class="num">0</span>, BUF_SIZE);
        <span class="fn">recv</span>(sock_fd, buf, BUF_SIZE, <span class="num">0</span>);
        <span class="fn">printf</span>(<span class="str">"%s\\n"</span>, buf);
    }
    <span class="fn">close</span>(sock_fd);
    <span class="kw">return</span> <span class="num">0</span>;
}`,
